FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=4000

COPY package.json ./
RUN npm install --omit=dev

COPY --chown=node:node src ./src
COPY --chown=node:node openapi.yaml ./openapi.yaml
COPY --chown=node:node .env.example ./.env.example

USER node

EXPOSE 4000

CMD ["node", "src/server.js"]

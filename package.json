{
  "name": "sql-nosql-syntax-validator",
  "version": "1.1.0",
  "description": "SQL/NoSQL Syntax Validator - Arquitectura MVC, Autenticación y Despliegue en Railway",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "install-deps": "npm install",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:api": "jest tests/api --runInBand",
    "test:mutation": "stryker run",
    "test:mutation:summary": "node scripts/mutation-summary.js",
    "test:bdd": "cucumber-js",
    "test:bdd:summary": "node scripts/bdd-summary.js"
  },
  "keywords": [
    "sql",
    "nosql",
    "validator",
    "mongodb",
    "syntax",
    "mvc",
    "railway",
    "postgresql"
  ],
  "author": "SQL/NoSQL Validator - Universidad Privada de Tacna",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@stryker-mutator/core": "^8.7.1",
    "jest": "^30.4.2",
    "multiple-cucumber-html-reporter": "^4.0.0",
    "nodemon": "^3.0.2",
    "snyk-to-html": "^3.7.6",
    "supertest": "^7.1.1"
  }
}
